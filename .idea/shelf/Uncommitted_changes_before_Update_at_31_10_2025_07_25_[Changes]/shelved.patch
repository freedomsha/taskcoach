+            try:
+                reactor.threadpool.stop()
+                log.debug("Application.stopTwisted : avec la méthode threadpool().stop().")
+            except AttributeError:
+                log.debug("Application.stopTwisted : aucune méthode ne fonctionne pour arrêter les workers.")
